[Unit]
Description=VSP Image Scan API (:8090 /scan -> trivy/cosign)
After=network.target

[Service]
Type=simple
User=devsecops
WorkingDirectory=/home/devsecops/vsp-platform-v4.9.0
ExecStart=/usr/bin/python3 /home/devsecops/vsp-platform-v4.9.0/bin/vsp-scan-api.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
